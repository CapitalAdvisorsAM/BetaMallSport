generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoLocal {
  LOCAL_COMERCIAL
  SIMULADOR
  MODULO
  ESPACIO
  BODEGA
  OTRO
}

enum EstadoMaestro {
  ACTIVO
  INACTIVO
}

enum EstadoContrato {
  VIGENTE
  TERMINADO
  TERMINADO_ANTICIPADO
  GRACIA
}

enum TipoTarifaContrato {
  FIJO_UF_M2
  FIJO_UF
  // PORCENTAJE se usa para renta variable (%) con vigencias en ContratoTarifa.
  PORCENTAJE
}

enum EstadoDiaContrato {
  OCUPADO
  GRACIA
  VACANTE
}

enum TipoCargaDatos {
  LOCALES
  ARRENDATARIOS
  RENT_ROLL
  VENTAS
  CONTABLE
  BANCO
}

enum EstadoCargaDatos {
  PENDIENTE
  PROCESANDO
  OK
  ERROR
}

enum UserRole {
  ADMIN
  CONTABILIDAD
  OPERACIONES
  GERENCIA
}

model Proyecto {
  id             String           @id @default(uuid()) @db.Uuid
  nombre         String
  slug           String           @unique
  color          String
  activo         Boolean          @default(true)
  createdAt      DateTime         @default(now()) @db.Timestamptz(3)
  locales              Local[]
  ventaLocales         VentaLocal[]
  ingresoEnergia       IngresoEnergia[]
  arrendatarios        Arrendatario[]
  contratos            Contrato[]
  contratosDia         ContratoDia[]
  cargasDatos          CargaDatos[]
  mapeosLocalContable  MapeoLocalContable[]
  mapeosVentasLocal    MapeoVentasLocal[]
  registrosContables   RegistroContable[]

  @@index([activo])
  @@index([nombre])
}

model ValorUF {
  id    String   @id @default(uuid()) @db.Uuid
  fecha DateTime @unique @db.Date
  valor Decimal  @db.Decimal(10, 4)
}

model Local {
  id         String        @id @default(uuid()) @db.Uuid
  proyectoId String        @db.Uuid
  codigo     String
  nombre     String
  glam2      Decimal       @db.Decimal(10, 2)
  piso       String
  tipo       TipoLocal
  zona       String?
  esGLA      Boolean       @default(true)
  estado     EstadoMaestro @default(ACTIVO)
  createdAt  DateTime      @default(now()) @db.Timestamptz(3)

  proyecto             Proyecto             @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  contratos            Contrato[]
  contratosAsociados   ContratoLocal[]
  contratosDia         ContratoDia[]
  ventaLocales         VentaLocal[]
  ingresoEnergia       IngresoEnergia[]
  mapeosLocalContable  MapeoLocalContable[]
  mapeosVentasLocal    MapeoVentasLocal[]
  registrosContables   RegistroContable[]

  @@unique([proyectoId, codigo])
  @@index([proyectoId])
  @@index([estado])
  @@index([proyectoId, estado])
}

model IngresoEnergia {
  id         String   @id @default(uuid()) @db.Uuid
  proyectoId String   @db.Uuid
  localId    String   @db.Uuid
  periodo    String
  valorUf    Decimal  @db.Decimal(14, 4)
  createdAt  DateTime @default(now()) @db.Timestamptz(3)

  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  local    Local    @relation(fields: [localId], references: [id], onDelete: Cascade)

  @@unique([localId, periodo])
  @@index([proyectoId, periodo])
}

model VentaLocal {
  id         String   @id @default(uuid()) @db.Uuid
  proyectoId String   @db.Uuid
  localId    String   @db.Uuid
  periodo    String
  ventasUf   Decimal  @db.Decimal(14, 4)
  createdAt  DateTime @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @db.Timestamptz(3)

  proyecto Proyecto @relation(fields: [proyectoId], references: [id])
  local    Local    @relation(fields: [localId], references: [id])

  @@unique([localId, periodo])
  @@index([proyectoId, periodo])
}

model Arrendatario {
  id              String   @id @default(uuid()) @db.Uuid
  proyectoId      String   @db.Uuid
  rut             String
  razonSocial     String
  nombreComercial String
  vigente         Boolean  @default(true)
  email           String?
  telefono        String?
  createdAt       DateTime @default(now()) @db.Timestamptz(3)

  proyecto           Proyecto           @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  contratos          Contrato[]
  registrosContables RegistroContable[]

  @@unique([proyectoId, rut])
  @@index([proyectoId])
  @@index([vigente])
  @@index([proyectoId, vigente])
}

model Contrato {
  id                String         @id @default(uuid()) @db.Uuid
  proyectoId        String         @db.Uuid
  localId           String         @db.Uuid
  arrendatarioId    String         @db.Uuid
  numeroContrato    String
  fechaInicio       DateTime       @db.Date
  fechaTermino      DateTime       @db.Date
  fechaEntrega      DateTime?      @db.Date
  fechaApertura     DateTime?      @db.Date
  pctFondoPromocion Decimal?       @db.Decimal(6, 3)
  codigoCC          String?
  estado            EstadoContrato
  pdfUrl            String?
  notas             String?
  createdAt         DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime       @updatedAt @db.Timestamptz(3)

  proyecto     Proyecto         @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  local        Local            @relation(fields: [localId], references: [id], onDelete: Restrict)
  arrendatario Arrendatario     @relation(fields: [arrendatarioId], references: [id], onDelete: Restrict)
  locales      ContratoLocal[]
  tarifas      ContratoTarifa[]
  anexos       ContratoAnexo[]
  ggcc         ContratoGGCC[]
  contratosDia ContratoDia[]

  @@unique([proyectoId, numeroContrato])
  @@index([proyectoId])
  @@index([localId])
  @@index([arrendatarioId])
  @@index([estado])
  @@index([proyectoId, estado])
  @@index([proyectoId, updatedAt])
}

model ContratoLocal {
  id         String   @id @default(uuid()) @db.Uuid
  contratoId String   @db.Uuid
  localId    String   @db.Uuid
  createdAt  DateTime @default(now()) @db.Timestamptz(3)

  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  local    Local    @relation(fields: [localId], references: [id], onDelete: Cascade)

  @@unique([contratoId, localId])
  @@index([contratoId])
  @@index([localId])
}

model ContratoTarifa {
  id            String             @id @default(uuid()) @db.Uuid
  contratoId    String             @db.Uuid
  tipo          TipoTarifaContrato
  valor         Decimal            @db.Decimal(10, 4)
  vigenciaDesde DateTime           @db.Date
  vigenciaHasta DateTime?          @db.Date
  esDiciembre   Boolean            @default(false)
  createdAt     DateTime           @default(now()) @db.Timestamptz(3)

  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@index([contratoId])
  @@index([vigenciaDesde, vigenciaHasta])
  @@index([contratoId, tipo, vigenciaDesde])
}

model ContratoAnexo {
  id                String   @id @default(uuid()) @db.Uuid
  contratoId        String   @db.Uuid
  fecha             DateTime @db.Date
  descripcion       String
  camposModificados Json
  snapshotAntes     Json
  snapshotDespues   Json
  usuarioId         String   @db.Uuid
  createdAt         DateTime @default(now()) @db.Timestamptz(3)

  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@index([contratoId])
  @@index([contratoId, fecha])
  @@index([usuarioId])
}

model ContratoGGCC {
  id                String    @id @default(uuid()) @db.Uuid
  contratoId        String    @db.Uuid
  tarifaBaseUfM2    Decimal   @db.Decimal(10, 4)
  pctAdministracion Decimal   @db.Decimal(6, 3)
  vigenciaDesde     DateTime  @db.Date
  vigenciaHasta     DateTime? @db.Date
  proximoReajuste   DateTime? @db.Date
  mesesReajuste     Int?
  createdAt         DateTime  @default(now()) @db.Timestamptz(3)

  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@index([contratoId])
  @@index([contratoId, vigenciaDesde])
}

model ContratoDia {
  id         String            @id @default(uuid()) @db.Uuid
  proyectoId String            @db.Uuid
  localId    String            @db.Uuid
  contratoId String?           @db.Uuid
  fecha      DateTime          @db.Date
  tarifaDia  Decimal           @db.Decimal(10, 4)
  estadoDia  EstadoDiaContrato
  glam2      Decimal           @db.Decimal(10, 2)
  ufDia      Decimal?          @db.Decimal(10, 4)
  createdAt  DateTime          @default(now()) @db.Timestamptz(3)

  proyecto Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  local    Local     @relation(fields: [localId], references: [id], onDelete: Restrict)
  contrato Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@unique([localId, fecha])
  @@index([proyectoId])
  @@index([proyectoId, fecha])
  @@index([contratoId])
}

model CargaDatos {
  id                String           @id @default(uuid()) @db.Uuid
  proyectoId        String           @db.Uuid
  tipo              TipoCargaDatos
  usuarioId         String           @db.Uuid
  archivoNombre     String
  archivoUrl        String
  registrosCargados Int              @default(0)
  estado            EstadoCargaDatos
  errorDetalle      Json?
  createdAt         DateTime         @default(now()) @db.Timestamptz(3)

  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@index([proyectoId])
  @@index([tipo])
  @@index([proyectoId, tipo])
  @@index([estado])
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String?
  email         String?   @unique
  emailVerified DateTime? @db.Timestamptz(3)
  image         String?
  role          UserRole  @default(OPERACIONES)
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime @db.Timestamptz(3)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model MapeoLocalContable {
  id           String   @id @default(uuid()) @db.Uuid
  proyectoId   String   @db.Uuid
  localExterno String
  localId      String   @db.Uuid
  creadoPor    String   @db.Uuid
  createdAt    DateTime @default(now()) @db.Timestamptz(3)

  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  local    Local    @relation(fields: [localId], references: [id], onDelete: Cascade)

  @@unique([proyectoId, localExterno])
  @@index([proyectoId])
  @@index([localId])
}

model RegistroContable {
  id              String   @id @default(uuid()) @db.Uuid
  proyectoId      String   @db.Uuid
  localId         String   @db.Uuid
  arrendatarioId  String?  @db.Uuid
  periodo         DateTime @db.Date
  grupo1          String
  grupo3          String
  denominacion    String
  valorUf         Decimal  @db.Decimal(14, 4)
  categoriaTamano String?
  categoriaTipo   String?
  piso            String?
  createdAt       DateTime @default(now()) @db.Timestamptz(3)

  proyecto     Proyecto      @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  local        Local         @relation(fields: [localId], references: [id], onDelete: Cascade)
  arrendatario Arrendatario? @relation(fields: [arrendatarioId], references: [id], onDelete: SetNull)

  @@unique([localId, periodo, grupo1, grupo3, denominacion])
  @@index([proyectoId, periodo])
  @@index([localId, periodo])
  @@index([arrendatarioId, periodo])
  @@index([proyectoId, grupo1, periodo])
}

model MapeoVentasLocal {
  id           String   @id @default(uuid()) @db.Uuid
  proyectoId   String   @db.Uuid
  idCa         Int
  tiendaNombre String
  localId      String   @db.Uuid
  creadoPor    String   @db.Uuid
  createdAt    DateTime @default(now()) @db.Timestamptz(3)

  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  local    Local    @relation(fields: [localId], references: [id], onDelete: Cascade)

  @@unique([proyectoId, idCa])
  @@index([proyectoId])
  @@index([localId])
}
