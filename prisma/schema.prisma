generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum UnitType {
  LOCAL_COMERCIAL
  SIMULADOR
  MODULO
  ESPACIO
  BODEGA
  OLA
  MAQUINA_EXPENDEDORA
  OTRO

  @@map("TipoLocal")
}

enum MasterStatus {
  ACTIVO
  INACTIVO

  @@map("EstadoMaestro")
}

enum ContractStatus {
  VIGENTE
  NO_INICIADO
  TERMINADO
  TERMINADO_ANTICIPADO
  GRACIA

  @@map("EstadoContrato")
}

enum ContractRateType {
  FIJO_UF_M2
  FIJO_UF
  // PORCENTAJE se usa para renta variable (%) con vigencias en ContractRate.
  PORCENTAJE

  @@map("TipoTarifaContrato")
}

enum ContractDiscountType {
  PORCENTAJE
  MONTO_UF

  @@map("TipoDescuentoTarifa")
}

enum TenantCategory {
  ENTERTAINMENT
  LIFESTYLE
  SERVICES
  POWERSPORTS
  OUTDOOR
  ACCESSORIES
  MULTISPORT
  BICYCLES
  GYM
}

enum BillingAlertSeverity {
  WARNING
  CRITICAL

  @@map("SeveridadAlertaFacturacion")
}

enum ContractDayStatus {
  OCUPADO
  GRACIA
  VACANTE

  @@map("EstadoDiaContrato")
}

enum DataUploadType {
  UNITS          @map("LOCALES")
  TENANTS        @map("ARRENDATARIOS")
  RENT_ROLL
  SALES          @map("VENTAS")
  SALES_DAILY    @map("VENTAS_DIARIAS")
  ACCOUNTING     @map("CONTABLE")
  BALANCES       @map("BALANCES")
  BANK           @map("BANCO")
  BUDGETED_SALES @map("VENTAS_PRESUPUESTADAS")
  EXPENSE_BUDGET @map("PPTO_GASTOS")

  @@map("TipoCargaDatos")
}

enum DataUploadStatus {
  PENDING    @map("PENDIENTE")
  PROCESSING @map("PROCESANDO")
  OK
  ERROR

  @@map("EstadoCargaDatos")
}

enum AccountType {
  INGRESO
  COSTO
  INVERSION
  OTRO
}

enum AccountingScenario {
  REAL
  PPTO
}

enum UserRole {
  ADMIN
  CONTABILIDAD
  OPERACIONES
  GERENCIA
}

model Project {
  id                       String                    @id @default(uuid()) @db.Uuid
  nombre                   String
  slug                     String                    @unique
  color                    String
  glaTotal                 Decimal?                  @db.Decimal(12, 2)
  activo                   Boolean                   @default(true)
  reportDate               DateTime?                 @map("fechaReporte") @db.Date
  createdAt                DateTime                  @default(now()) @db.Timestamptz(3)
  locales                  Unit[]
  zones                    Zone[]
  tenantSales              TenantSale[]
  tenantSalesDaily         TenantSaleDaily[]
  tenantBudgetedSales      TenantBudgetedSale[]
  ingresoEnergia           IngresoEnergia[]
  arrendatarios            Tenant[]
  contratos                Contract[]
  contratosDia             ContractDay[]
  dataUploads              DataUpload[]
  accountingUnitMappings   AccountingUnitMapping[]
  accountingTenantMappings AccountingTenantMapping[]
  chartOfAccounts          ChartOfAccount[]
  salesTenantMappings      SalesTenantMapping[]
  accountingRecords        AccountingRecord[]
  billingAlerts            BillingAlert[]
  expenseBudgets           ExpenseBudget[]
  balanceRecords           BalanceRecord[]
  bankMovements            BankMovement[]

  @@index([activo])
  @@index([nombre])
  @@map("Proyecto")
}

model ValorUF {
  id    String   @id @default(uuid()) @db.Uuid
  fecha DateTime @unique @db.Date
  valor Decimal  @db.Decimal(10, 4)
}

model Unit {
  id              String       @id @default(uuid()) @db.Uuid
  projectId       String       @map("proyectoId") @db.Uuid
  codigo          String
  nombre          String
  glam2           Decimal      @db.Decimal(10, 2)
  piso            String
  tipo            UnitType
  zonaId          String?      @db.Uuid
  categoriaTamano String?      @map("categoriaTamano")
  esGLA           Boolean      @default(true)
  estado          MasterStatus @default(ACTIVO)
  createdAt       DateTime     @default(now()) @db.Timestamptz(3)

  proyecto               Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zona                   Zone?                   @relation(fields: [zonaId], references: [id], onDelete: SetNull)
  contratos              Contract[]
  contratosAsociados     ContractUnit[]
  contratosDia           ContractDay[]
  ingresoEnergia         IngresoEnergia[]
  accountingUnitMappings AccountingUnitMapping[]
  accountingRecords      AccountingRecord[]

  @@unique([projectId, codigo])
  @@unique([id, projectId])
  @@index([projectId])
  @@index([zonaId])
  @@index([estado])
  @@index([projectId, estado])
  @@map("Local")
}

model Zone {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("proyectoId") @db.Uuid
  nombre    String
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  proyecto Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  units    Unit[]

  @@unique([projectId, nombre])
  @@index([projectId])
  @@map("ZonaLocal")
}

model IngresoEnergia {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("proyectoId") @db.Uuid
  localId   String   @db.Uuid
  periodo   DateTime @db.Date
  valorUf   Decimal  @db.Decimal(14, 4)
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  proyecto Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  local    Unit    @relation(fields: [localId, projectId], references: [id, projectId], onDelete: Cascade)

  @@unique([localId, periodo])
  @@index([projectId, periodo])
  @@index([localId, periodo])
}

model TenantSale {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @map("proyectoId") @db.Uuid
  tenantId   String   @map("arrendatarioId") @db.Uuid
  period     DateTime @map("periodo") @db.Date
  salesPesos Decimal  @map("ventasPesos") @db.Decimal(18, 2)
  createdAt  DateTime @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId, projectId], references: [id, projectId])

  @@unique([tenantId, period])
  @@index([projectId, period])
  @@map("VentaArrendatario")
}

model TenantBudgetedSale {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @map("proyectoId") @db.Uuid
  tenantId   String   @map("arrendatarioId") @db.Uuid
  period     DateTime @map("periodo") @db.Date
  salesPesos Decimal  @map("ventasPesos") @db.Decimal(18, 2)
  createdAt  DateTime @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id])
  tenant  Tenant  @relation(fields: [tenantId, projectId], references: [id, projectId])

  @@unique([tenantId, period])
  @@index([projectId, period])
  @@map("VentaPresupuestadaArrendatario")
}

model TenantSaleDaily {
  id                   String    @id @default(uuid()) @db.Uuid
  projectId            String    @map("proyectoId") @db.Uuid
  tenantId             String?   @map("arrendatarioId") @db.Uuid
  salesAccountId       String    @map("idCa")
  storeName            String    @map("tiendaNombre")
  date                 DateTime  @map("fecha") @db.Date
  period               DateTime  @map("periodo") @db.Date
  day                  Int       @map("dia")
  totalReceipts        Decimal   @map("totalBoletas") @db.Decimal(18, 2)
  totalExemptReceipts  Decimal   @map("totalBoletasExentas") @db.Decimal(18, 2)
  totalInvoices        Decimal   @map("totalFacturas") @db.Decimal(18, 2)
  totalCreditNotes     Decimal   @map("totalNotasCredito") @db.Decimal(18, 2)
  salesPesos           Decimal   @map("ventasPesos") @db.Decimal(18, 2)
  registrationDate     DateTime? @map("fechaRegistro") @db.Date
  sizeCategory         String?   @map("categoriaTamano")
  typeCategory         String?   @map("categoriaTipo")
  floor                String?   @map("piso")
  glaType              String?   @map("glaTipo")
  createdAt            DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime  @updatedAt @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id])
  tenant  Tenant? @relation(fields: [tenantId, projectId], references: [id, projectId])

  @@unique([projectId, salesAccountId, storeName, date])
  @@index([projectId, date])
  @@index([projectId, period])
  @@index([tenantId, date])
  @@map("VentaArrendatarioDiaria")
}

model Tenant {
  id              String          @id @default(uuid()) @db.Uuid
  projectId       String          @map("proyectoId") @db.Uuid
  rut             String
  razonSocial     String
  nombreComercial String
  vigente         Boolean         @default(true)
  email           String?
  telefono        String?
  category        TenantCategory?
  createdAt       DateTime        @default(now()) @db.Timestamptz(3)

  proyecto                 Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contratos                Contract[]
  tenantSales              TenantSale[]
  tenantSalesDaily         TenantSaleDaily[]
  tenantBudgetedSales      TenantBudgetedSale[]
  salesTenantMappings      SalesTenantMapping[]
  accountingTenantMappings AccountingTenantMapping[]
  accountingRecords        AccountingRecord[]
  billingAlerts            BillingAlert[]

  @@unique([projectId, rut])
  @@unique([id, projectId])
  @@index([projectId])
  @@index([vigente])
  @@index([projectId, vigente])
  @@map("Arrendatario")
}

model Contract {
  id                     String         @id @default(uuid()) @db.Uuid
  projectId              String         @map("proyectoId") @db.Uuid
  localId                String         @db.Uuid
  arrendatarioId         String         @db.Uuid
  numeroContrato         String
  fechaInicio            DateTime       @db.Date
  fechaTermino           DateTime       @db.Date
  fechaEntrega           DateTime?      @db.Date
  fechaApertura          DateTime?      @db.Date
  pctFondoPromocion      Decimal?       @db.Decimal(6, 3)
  /// @deprecated Default de formulario únicamente. Valor canónico está en ContratoGGCC.pctAdministracion.
  /// No agregar nuevas lecturas/escrituras a este campo.
  pctAdministracionGgcc  Decimal?       @db.Decimal(6, 3)
  multiplicadorDiciembre Decimal?       @db.Decimal(6, 3)
  multiplicadorJunio     Decimal?       @db.Decimal(6, 3)
  multiplicadorJulio     Decimal?       @db.Decimal(6, 3)
  multiplicadorAgosto    Decimal?       @db.Decimal(6, 3)
  codigoCC               String?
  estado                 ContractStatus
  diasGracia             Int            @default(0)
  cuentaParaVacancia     Boolean        @default(true)
  pdfUrl                 String?
  notas                  String?
  createdAt              DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime       @updatedAt @db.Timestamptz(3)

  proyecto     Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  local        Unit                    @relation(fields: [localId, projectId], references: [id, projectId], onDelete: Restrict)
  arrendatario Tenant                  @relation(fields: [arrendatarioId, projectId], references: [id, projectId], onDelete: Restrict)
  locales      ContractUnit[]
  tarifas      ContractRate[]
  anexos       ContractAmendment[]
  ggcc         ContractCommonExpense[]
  contratosDia ContractDay[]

  @@unique([projectId, numeroContrato])
  @@unique([id, projectId])
  @@index([projectId])
  @@index([localId])
  @@index([arrendatarioId])
  @@index([estado])
  @@index([projectId, estado])
  @@index([projectId, updatedAt])
  @@index([projectId, fechaInicio, fechaTermino])
  @@map("Contrato")
}

model ContractUnit {
  id         String   @id @default(uuid()) @db.Uuid
  contratoId String   @db.Uuid
  localId    String   @db.Uuid
  createdAt  DateTime @default(now()) @db.Timestamptz(3)

  contrato Contract @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  local    Unit     @relation(fields: [localId], references: [id], onDelete: Cascade)

  @@unique([contratoId, localId])
  @@index([contratoId])
  @@index([localId])
  @@map("ContratoLocal")
}

model ContractRate {
  id             String                @id @default(uuid()) @db.Uuid
  contratoId     String                @db.Uuid
  tipo           ContractRateType
  valor          Decimal               @db.Decimal(10, 4)
  umbralVentasUf Decimal?              @db.Decimal(14, 4)
  /// Piso mínimo mensual en UF aplicable sólo a tarifas PORCENTAJE.
  /// Cuando está definido se cobra max(fixedRent+variable, pisoMinimoUf) mensualmente.
  pisoMinimoUf   Decimal?              @db.Decimal(14, 4)
  vigenciaDesde  DateTime              @db.Date
  vigenciaHasta  DateTime?             @db.Date
  esDiciembre    Boolean               @default(false)
  /// @deprecated Reemplazado por ContractRateDiscount (descuentos como entidad temporal aparte).
  /// No agregar nuevas lecturas/escrituras a estos campos.
  descuentoTipo  ContractDiscountType?
  descuentoValor Decimal?              @db.Decimal(10, 4)
  descuentoDesde DateTime?             @db.Date
  descuentoHasta DateTime?             @db.Date
  createdAt      DateTime              @default(now()) @db.Timestamptz(3)

  /// Bitemporal supersession (transaction time).
  /// supersededAt IS NULL = fila vigente para la verdad actual.
  /// Para reconstruir "lo que se sabía en T": filtrar createdAt <= T AND (supersededAt IS NULL OR supersededAt > T).
  supersededAt    DateTime? @db.Timestamptz(3)
  supersededBy    String?   @db.Uuid
  supersedeReason String?
  amendmentId     String?   @db.Uuid

  contrato  Contract               @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  amendment ContractAmendment?     @relation(fields: [amendmentId], references: [id], onDelete: SetNull)
  discounts ContractRateDiscount[]

  @@index([contratoId])
  @@index([vigenciaDesde, vigenciaHasta])
  @@index([contratoId, tipo, vigenciaDesde])
  @@index([contratoId, supersededAt])
  @@map("ContratoTarifa")
}

model ContractRateDiscount {
  id             String               @id @default(uuid()) @db.Uuid
  contractRateId String               @db.Uuid
  tipo           ContractDiscountType
  valor          Decimal              @db.Decimal(10, 4)
  vigenciaDesde  DateTime             @db.Date
  vigenciaHasta  DateTime?            @db.Date
  createdAt      DateTime             @default(now()) @db.Timestamptz(3)

  /// Bitemporal supersession — ver comentario en ContractRate.
  supersededAt    DateTime? @db.Timestamptz(3)
  supersededBy    String?   @db.Uuid
  supersedeReason String?
  amendmentId     String?   @db.Uuid

  contractRate ContractRate       @relation(fields: [contractRateId], references: [id], onDelete: Cascade)
  amendment    ContractAmendment? @relation(fields: [amendmentId], references: [id], onDelete: SetNull)

  @@index([contractRateId])
  @@index([contractRateId, supersededAt])
  @@index([contractRateId, vigenciaDesde])
  @@map("ContratoTarifaDescuento")
}

model ContractAmendment {
  id                String   @id @default(uuid()) @db.Uuid
  contratoId        String   @db.Uuid
  fecha             DateTime @db.Date
  descripcion       String
  camposModificados Json
  snapshotAntes     Json
  snapshotDespues   Json
  usuarioId         String   @db.Uuid
  createdAt         DateTime @default(now()) @db.Timestamptz(3)

  contrato       Contract                @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  rates          ContractRate[]
  discounts      ContractRateDiscount[]
  commonExpenses ContractCommonExpense[]

  @@index([contratoId])
  @@index([contratoId, fecha])
  @@index([usuarioId])
  @@map("ContratoAnexo")
}

model ContractCommonExpense {
  id                String    @id @default(uuid()) @db.Uuid
  contratoId        String    @db.Uuid
  tarifaBaseUfM2    Decimal   @db.Decimal(10, 4)
  pctAdministracion Decimal   @db.Decimal(6, 3)
  pctReajuste       Decimal?  @db.Decimal(6, 3)
  vigenciaDesde     DateTime  @db.Date
  vigenciaHasta     DateTime? @db.Date
  proximoReajuste   DateTime? @db.Date
  mesesReajuste     Int?
  createdAt         DateTime  @default(now()) @db.Timestamptz(3)

  /// Bitemporal supersession — same semantics as ContractRate.
  /// supersededAt IS NULL = fila vigente para la verdad actual.
  supersededAt    DateTime? @db.Timestamptz(3)
  supersededBy    String?   @db.Uuid
  supersedeReason String?
  amendmentId     String?   @db.Uuid

  contrato  Contract           @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  amendment ContractAmendment? @relation(fields: [amendmentId], references: [id], onDelete: SetNull)

  @@index([contratoId])
  @@index([contratoId, vigenciaDesde])
  @@index([contratoId, supersededAt])
  @@map("ContratoGGCC")
}

model ContractDay {
  id         String            @id @default(uuid()) @db.Uuid
  projectId  String            @map("proyectoId") @db.Uuid
  localId    String            @db.Uuid
  contratoId String?           @db.Uuid
  fecha      DateTime          @db.Date
  tarifaDia  Decimal           @db.Decimal(10, 4)
  estadoDia  ContractDayStatus
  glam2      Decimal           @db.Decimal(10, 2)
  ufDia      Decimal?          @db.Decimal(10, 4)
  createdAt  DateTime          @default(now()) @db.Timestamptz(3)

  proyecto Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  local    Unit      @relation(fields: [localId], references: [id], onDelete: Restrict)
  contrato Contract? @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@unique([localId, fecha])
  @@index([projectId])
  @@index([projectId, fecha])
  @@index([contratoId])
  @@map("ContratoDia")
}

model DataUpload {
  id            String           @id @default(uuid()) @db.Uuid
  projectId     String           @map("proyectoId") @db.Uuid
  type          DataUploadType   @map("tipo")
  userId        String           @map("usuarioId") @db.Uuid
  fileName      String           @map("archivoNombre")
  fileUrl       String           @map("archivoUrl")
  recordsLoaded Int              @default(0) @map("registrosCargados")
  status        DataUploadStatus @map("estado")
  errorDetail   Json?            @map("errorDetalle")
  createdAt     DateTime         @default(now()) @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([type])
  @@index([projectId, type])
  @@index([status])
  @@index([projectId, type, createdAt])
  @@map("CargaDatos")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String?
  email         String?   @unique
  emailVerified DateTime? @db.Timestamptz(3)
  image         String?
  role          UserRole  @default(OPERACIONES)
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime @db.Timestamptz(3)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AccountingUnitMapping {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("proyectoId") @db.Uuid
  externalUnit String   @map("localExterno")
  unitId       String   @map("localId") @db.Uuid
  createdBy    String   @map("creadoPor") @db.Uuid
  createdAt    DateTime @default(now()) @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  unit    Unit    @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([projectId, externalUnit])
  @@index([projectId])
  @@index([unitId])
  @@map("MapeoLocalContable")
}

model AccountingTenantMapping {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @map("proyectoId") @db.Uuid
  externalTenant String   @map("arrendatarioExterno")
  tenantId       String   @map("arrendatarioId") @db.Uuid
  createdBy      String   @map("creadoPor") @db.Uuid
  createdAt      DateTime @default(now()) @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId, projectId], references: [id, projectId], onDelete: Cascade)

  @@unique([projectId, externalTenant])
  @@index([projectId])
  @@index([tenantId])
  @@map("MapeoArrendatarioContable")
}

model ChartOfAccount {
  id           String       @id @default(uuid()) @db.Uuid
  projectId    String       @map("proyectoId") @db.Uuid
  group0       String       @default("") @map("grupo0")
  group1       String       @map("grupo1")
  group2       String       @default("") @map("grupo2")
  group3       String       @map("grupo3")
  type         AccountType? @map("tipo")
  alias        String?
  displayOrder Int?         @map("orden")
  notes        String?      @map("notas")
  createdAt    DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime     @updatedAt @db.Timestamptz(3)

  project Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  records AccountingRecord[]

  @@unique([projectId, group0, group1, group2, group3])
  @@index([projectId])
  @@index([projectId, group1])
  @@index([projectId, type])
  @@map("PlanDeCuentas")
}

model AccountingRecord {
  id                    String             @id @default(uuid()) @db.Uuid
  projectId             String             @map("proyectoId") @db.Uuid
  unitId                String?            @map("localId") @db.Uuid
  tenantId              String?            @map("arrendatarioId") @db.Uuid
  chartOfAccountId      String?            @map("planDeCuentasId") @db.Uuid
  externalUnit          String?            @map("localExterno")
  externalTenant        String?            @map("arrendatarioExterno")
  period                DateTime           @map("periodo") @db.Date
  group0                String?            @map("grupo0")
  group1                String             @map("grupo1")
  group2                String?            @map("grupo2")
  group3                String             @map("grupo3")
  denomination          String             @map("denominacion")
  costCenterCode        String?            @map("clCoste")
  costCenterDescription String?            @map("descripcionClCoste")
  valueUf               Decimal            @map("valorUf") @db.Decimal(14, 4)
  valueClp              Decimal?           @map("valorClp") @db.Decimal(18, 2)
  sizeCategory          String?            @map("categoriaTamano")
  typeCategory          String?            @map("categoriaTipo")
  floor                 String?            @map("piso")
  documentRef           String?            @map("documento")
  documentHeader        String?            @map("textoCabDocumento")
  glaFlag               Boolean?           @map("esGla")
  scenario              AccountingScenario @default(REAL) @map("escenario")
  createdAt             DateTime           @default(now()) @db.Timestamptz(3)

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  unit           Unit?           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant         Tenant?         @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  chartOfAccount ChartOfAccount? @relation(fields: [chartOfAccountId], references: [id], onDelete: SetNull)

  // @@unique removed — replaced by two partial unique indexes in migration SQL
  // to correctly handle nullable unitId (NULL != NULL in PG unique constraints).
  @@index([projectId, period])
  @@index([unitId, period])
  @@index([tenantId, period])
  @@index([projectId, group1, period])
  @@index([projectId, group3, period])
  @@index([projectId, group0, period])
  @@index([projectId, group2, period])
  @@index([projectId, tenantId, period])
  @@index([chartOfAccountId, period])
  @@index([projectId, scenario, period])
  @@index([projectId, scenario, group3, period])
  @@map("RegistroContable")
}

model CustomWidget {
  id            String   @id @default(uuid()) @db.Uuid
  title         String
  chartType     String   @default("line")
  enabled       Boolean  @default(true)
  position      Int      @default(0)
  formulaConfig Json
  createdAt     DateTime @default(now()) @db.Timestamptz(3)

  @@index([enabled])
}

model DashboardConfig {
  id             String  @id @default(uuid()) @db.Uuid
  widgetId       String  @unique
  enabled        Boolean @default(true)
  position       Int     @default(0)
  formulaVariant String?
  parameters     Json?

  @@index([enabled])
}

model SalesTenantMapping {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @map("proyectoId") @db.Uuid
  salesAccountId String   @map("idCa")
  storeName      String   @map("tiendaNombre")
  tenantId       String   @map("arrendatarioId") @db.Uuid
  createdBy      String   @map("creadoPor") @db.Uuid
  createdAt      DateTime @default(now()) @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId, projectId], references: [id, projectId], onDelete: Cascade)

  @@unique([projectId, salesAccountId, storeName])
  @@index([projectId])
  @@index([tenantId])
  @@map("MapeoVentasArrendatario")
}

model BillingAlert {
  id                String               @id @default(uuid()) @db.Uuid
  projectId         String               @map("proyectoId") @db.Uuid
  arrendatarioId    String               @db.Uuid
  severity          BillingAlertSeverity
  consecutiveMonths Int                  @map("mesesConsecutivos")
  avgGapPct         Decimal              @map("brechaPromedioPct") @db.Decimal(8, 2)
  latestPeriod      String               @map("ultimoPeriodo")
  resolvedAt        DateTime?            @map("resueltaEn") @db.Timestamptz(3)
  createdAt         DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime             @updatedAt @db.Timestamptz(3)

  proyecto     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  arrendatario Tenant  @relation(fields: [arrendatarioId, projectId], references: [id, projectId], onDelete: Cascade)

  @@unique([projectId, arrendatarioId])
  @@index([projectId])
  @@index([arrendatarioId])
  @@index([projectId, severity, resolvedAt])
  @@map("AlertaFacturacion")
}

model ExpenseBudget {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("proyectoId") @db.Uuid
  periodo   DateTime @db.Date
  grupo1    String
  grupo3    String
  valorUf   Decimal  @db.Decimal(14, 4)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, periodo, grupo1, grupo3])
  @@index([projectId, periodo])
  @@index([projectId, grupo1, periodo])
  @@map("PresupuestoGasto")
}

model BalanceRecord {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @map("proyectoId") @db.Uuid
  period         DateTime @map("periodo") @db.Date
  accountCode    String   @map("codigo")
  accountName    String   @map("nombre")
  accountNameAlt String?  @map("nombre2")
  debitsClp      Decimal  @map("debitosClp") @db.Decimal(18, 2)
  creditsClp     Decimal  @map("creditosClp") @db.Decimal(18, 2)
  debtorClp      Decimal  @map("deudorClp") @db.Decimal(18, 2)
  creditorClp    Decimal  @map("acreedorClp") @db.Decimal(18, 2)
  assetClp       Decimal  @map("activoClp") @db.Decimal(18, 2)
  liabilityClp   Decimal  @map("pasivoClp") @db.Decimal(18, 2)
  lossesClp      Decimal  @map("perdidasClp") @db.Decimal(18, 2)
  gainsClp       Decimal  @map("gananciasClp") @db.Decimal(18, 2)
  diffClp        Decimal  @map("diferenciaClp") @db.Decimal(18, 2)
  category       String   @map("categoria")
  groupName      String   @map("grupo")
  valueUf        Decimal  @map("valorUf") @db.Decimal(14, 4)
  createdAt      DateTime @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, period, accountCode])
  @@index([projectId, period])
  @@index([projectId, groupName, period])
  @@index([projectId, category, period])
  @@map("RegistroBalance")
}

model BankMovement {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @map("proyectoId") @db.Uuid
  period          DateTime @map("periodo") @db.Date
  accountingDate  DateTime @map("fechaContable") @db.Date
  account         String   @map("cc")
  movement        String   @map("movimiento")
  operationNumber String?  @map("numeroOperacion")
  amountClp       Decimal  @map("montoClp") @db.Decimal(18, 2)
  originRut       String?  @map("rutOrigen")
  originName      String?  @map("nombreOrigen")
  transferComment String?  @map("comentarioTransferencia")
  bank            String   @map("banco")
  classification  String   @map("clasificacion")
  createdAt       DateTime @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, accountingDate, account, operationNumber, amountClp])
  @@index([projectId, period])
  @@index([projectId, accountingDate])
  @@index([projectId, classification, period])
  @@map("MovimientoBanco")
}
