# =============================================================================
# DATABASE
# =============================================================================
# Cada desarrollador debe usar su propio branch de Neon para no pisar migraciones.
# Pasos:
#   1. Ir a https://console.neon.tech → tu proyecto → Branches → Create branch
#   2. Nombrar el branch igual que tu git branch (ej: "felipe", "alfredo")
#   3. Copiar el connection string del nuevo branch aquí
DATABASE_URL="postgresql://user:password@ep-tu-branch.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# =============================================================================
# NEXTAUTH
# =============================================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# =============================================================================
# GOOGLE OAUTH
# =============================================================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# =============================================================================
# APP CONFIG
# =============================================================================
ALLOWED_EMAIL_DOMAIN="capitaladvisors.cl"

# =============================================================================
# GCP (solo necesario para deploy, no para desarrollo local)
# =============================================================================
GCP_PROJECT_ID=""
GCP_REGION="southamerica-west1"
CLOUD_SQL_INSTANCE=""
GCS_BUCKET_NAME=""
